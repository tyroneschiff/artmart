{
  "expo": {
    "name": "Draw Up",
    "slug": "artmart",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "art.drawup.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "art.drawup.app",
      "supportsTablet": false,
      "buildNumber": "14",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Draw Up needs access to your photos to upload your child's artwork.",
          "cameraPermission": "Draw Up needs your camera to photograph your child's artwork."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.art.drawup.app",
          "enableGooglePay": false
        }
      ]
    ],
    "scheme": "drawup",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2b58ad6-41f8-47ed-95cc-76c2908eef90"
      }
    },
    "owner": "tyroneschiff"
  }
}