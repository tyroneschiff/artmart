{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/piece/:id",
      "destination": "/api/og?type=piece&id=:id"
    },
    {
      "source": "/gallery/:slug",
      "destination": "/api/og?type=gallery&id=:slug"
    }
  ],
  "redirects": [
    {
      "source": "/store/:slug",
      "destination": "/gallery/:slug",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/og-image.jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon|apple-touch-icon).(svg|png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=31536000, immutable" }
      ]
    }
  ]
}
