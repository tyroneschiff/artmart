{
  "rewrites": [
    {
      "source": "/piece/:id",
      "destination": "/api/og?type=piece&id=:id"
    },
    {
      "source": "/gallery/:slug",
      "destination": "/api/og?type=gallery&id=:slug"
    }
  ],
  "redirects": [
    {
      "source": "/store/:slug",
      "destination": "/gallery/:slug",
      "permanent": true
    }
  ]
}
